# Radar Tech (IA) — opcional.
# Puedes configurar la API key de Gemini aquí (servidor) O dentro de la app
# en Ajustes → Radar Tech (IA). Si defines esta variable, tiene prioridad.
#
# Consigue tu API key gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo a usar (por defecto: gemini-2.5-flash-lite — barato y con búsqueda web).
GEMINI_MODEL=gemini-2.5-flash-lite

# URL pública del sitio (para metadatos/Open Graph al compartir).
NEXT_PUBLIC_SITE_URL=
