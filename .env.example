# --- Supabase (backend real) ---
# En el panel de Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Radar Tech (IA) ---
# API key de Gemini (servidor). Consíguela gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo (por defecto: gemini-2.5-flash-lite — barato y con búsqueda web).
GEMINI_MODEL=gemini-2.5-flash-lite

# URL pública del sitio (para metadatos/Open Graph al compartir).
NEXT_PUBLIC_SITE_URL=
