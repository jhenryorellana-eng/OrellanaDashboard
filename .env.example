# --- Supabase (backend real) ---
# En el panel de Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Web Push (notificaciones) ---
# Llave PÚBLICA VAPID (va al cliente). La privada vive en Supabase (tabla push_config).
# Genera un par con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Radar Tech (IA) ---
# API key de Gemini (servidor). Consíguela gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo (por defecto: gemini-2.5-flash-lite — barato y con búsqueda web).
GEMINI_MODEL=gemini-2.5-flash-lite

# URL pública del sitio (para metadatos/Open Graph al compartir).
NEXT_PUBLIC_SITE_URL=
